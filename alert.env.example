# Copy to `alert.env` (git-ignored) to enable email alerts.
# Alerts are sent directly to each recipient domain's MX over SMTP :25 with
# opportunistic STARTTLS — no local mail server or SMTP relay required.

# Comma-separated recipients. Leave unset/empty to disable alerts entirely.
WM_ALERT_TO=you@example.com

# Envelope/From address (default: website-monitor@<host fqdn>).
WM_ALERT_FROM=website-monitor@example.com

# Optional: force a specific smarthost/relay and skip MX lookup.
# WM_SMTP_HOST=smtp.internal.example.com

# Optional: per-connection timeout in seconds (default 30).
# WM_SMTP_TIMEOUT=30
